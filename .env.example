# Resend API key used to send lead-notification emails from the website forms.
# Get one at https://resend.com/api-keys (free tier available).
RESEND_API_KEY=

# Mailbox that receives new lead notifications (booking form, ads/ppc landing pages).
LEAD_TO_EMAIL=office@hairtoppersisrael.com

# Sender identity for outgoing lead emails.
# hairtoppersisrael.com is verified in Resend — use it directly:
RESEND_FROM_EMAIL="David Hair Solutions <leads@hairtoppersisrael.com>"
